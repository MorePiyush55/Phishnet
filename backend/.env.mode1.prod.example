# Production Mode 1 Configuration
# USE SECRETS MANAGER FOR ALL CREDENTIALS
# NEVER COMMIT REAL CREDENTIALS

# ============================================================================
# Mode 1 Control
# ============================================================================
MODE1_ENABLED=true
MODE1_AUTO_START=true
MODE1_FAIL_FAST=false  # Graceful degradation in production
MODE1_STARTUP_HEALTH_CHECK=true

# ============================================================================
# IMAP Configuration (Production)
# ============================================================================
IMAP_CLIENT_TYPE=real  # Always use real IMAP in production

# CRITICAL: Use secrets manager, not environment variables
# Choose ONE of the following:

# Option 1: AWS Secrets Manager
AWS_SECRET_NAME=phishnet/mode1/imap-credentials
AWS_REGION=us-east-1

# Option 2: Google Cloud Secret Manager
GCP_SECRET_NAME=phishnet-mode1-imap
GCP_PROJECT_ID=your-project-id

# Option 3: HashiCorp Vault
VAULT_PATH=secret/phishnet/mode1
VAULT_ADDR=https://vault.example.com

# Fallback (NOT RECOMMENDED - use secrets manager instead)
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=DO-NOT-PUT-HERE
# IMAP_PASSWORD=USE-SECRETS-MANAGER

# ============================================================================
# Database (Production)
# ============================================================================
# Use connection strings from secrets manager
MONGODB_URI=${MONGODB_CONNECTION_STRING}  # From secrets manager
REDIS_URL=${REDIS_CONNECTION_STRING}  # From secrets manager

# ============================================================================
# External APIs (Production)
# ============================================================================
# Store API keys in secrets manager
VIRUSTOTAL_API_KEY=${VIRUSTOTAL_KEY}  # From secrets manager
GOOGLE_API_KEY=${GEMINI_KEY}  # From secrets manager
ABUSEIPDB_API_KEY=${ABUSEIPDB_KEY}  # From secrets manager

# ============================================================================
# Mode 1 Processing (Production)
# ============================================================================
MODE1_DEFAULT_POLL_INTERVAL=60
MODE1_BATCH_SIZE=50  # Production batch size
MODE1_MAX_CONCURRENT_TENANTS=10
MODE1_DEDUP_ENABLED=true
MODE1_POLICY_ENGINE_ENABLED=true

# ============================================================================
# Resilience & Performance
# ============================================================================
# Circuit breaker settings
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ============================================================================
# Monitoring & Alerting
# ============================================================================
# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# Alerting (configure your alerting service)
ALERT_WEBHOOK_URL=${ALERT_WEBHOOK}  # From secrets manager
SLACK_WEBHOOK_URL=${SLACK_WEBHOOK}  # From secrets manager

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
ENVIRONMENT=production
LOG_FORMAT=json  # Structured logging for production

# ============================================================================
# CRITICAL SECURITY NOTES
# ============================================================================
# 1. NEVER put real credentials in this file
# 2. ALWAYS use a secrets manager (AWS, GCP, Vault)
# 3. Rotate credentials regularly (every 90 days minimum)
# 4. Use app passwords for IMAP, not account passwords
# 5. Enable audit logging for all credential access
# 6. Monitor for unauthorized access attempts
# 7. Use least-privilege IAM roles
# 8. Enable encryption at rest and in transit
# 9. Set up alerting for circuit breaker opens
# 10. Review logs daily for anomalies

# ============================================================================
# Deployment Checklist
# ============================================================================
# [ ] Secrets manager configured
# [ ] Database indexes created
# [ ] Redis cluster configured
# [ ] Monitoring dashboards set up
# [ ] Alerting rules configured
# [ ] Backup strategy implemented
# [ ] Disaster recovery plan documented
# [ ] Load testing completed
# [ ] Security audit passed
# [ ] Compliance requirements met
