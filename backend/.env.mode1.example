# Mode 1 Configuration Example
# Copy this to .env and configure for your environment

# ============================================================================
# Mode 1 - Automatic IMAP Email Processing
# ============================================================================

# Enable Mode 1 orchestrator
MODE1_ENABLED=true

# Auto-start on application startup
MODE1_AUTO_START=true

# Polling configuration
MODE1_DEFAULT_POLL_INTERVAL=60  # seconds
MODE1_BATCH_SIZE=50  # emails per poll
MODE1_MAX_CONCURRENT_TENANTS=10

# Feature flags
MODE1_DEDUP_ENABLED=true
MODE1_POLICY_ENGINE_ENABLED=true

# ============================================================================
# IMAP Configuration (Default Mailbox)
# ============================================================================

# Enable IMAP polling
IMAP_ENABLED=true

# IMAP server settings
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=phishnet.ai@gmail.com
IMAP_PASSWORD=your-app-password-here
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL=60

# ============================================================================
# SMTP Configuration (For Reply Emails)
# ============================================================================

SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=phishnet.ai@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=phishnet.ai@gmail.com
SMTP_FROM_NAME=PhishNet Security

# ============================================================================
# Database Configuration
# ============================================================================

# MongoDB (Required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/phishnet?retryWrites=true&w=majority
MONGODB_DATABASE=phishnet

# Redis (Required for circuit breakers and rate limiting)
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# External API Keys
# ============================================================================

# VirusTotal (Optional but recommended)
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# AbuseIPDB (Optional but recommended)
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# Google Gemini AI (Optional for enhanced analysis)
GEMINI_API_KEY=your-gemini-api-key

# ============================================================================
# Security & Performance
# ============================================================================

# Circuit breaker thresholds
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# Multi-Tenant Configuration (Optional)
# ============================================================================

# If using multi-tenant mode, configure mailboxes via API:
# POST /api/v1/mode1/mailboxes
# {
#   "tenant_id": "acme-corp",
#   "tenant_domain": "acme.com",
#   "imap_host": "imap.gmail.com",
#   "imap_user": "phishnet@acme.com",
#   "imap_password": "app-password",
#   "poll_interval": 60
# }
