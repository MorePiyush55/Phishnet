  "features": [
    {
      "name": "Gmail OAuth Authentication",
      "description": "Complete Gmail OAuth 2.0 flow with secure token management, Google API integration, and user authentication",
      "files": [
        "backend/app/api/gmail_oauth.py",
        "backend/app/api/test_oauth.py",
        "backend/app/services/gmail_oauth.py",
        "frontend/src/contexts/AuthContext.tsx"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Gmail OAuth API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/v1/auth/gmail/start": {
            "post": {
              "summary": "Initiate Gmail OAuth flow",
              "responses": {
                "200": {
                  "description": "OAuth URL generated successfully",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "auth_url": {"type": "string"},
                          "state": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "/api/v1/auth/gmail/callback": {
            "get": {
              "summary": "Handle Gmail OAuth callback",
              "parameters": [
                {"name": "code", "in": "query", "required": true, "schema": {"type": "string"}},
                {"name": "state", "in": "query", "required": true, "schema": {"type": "string"}}
              ],
              "responses": {
                "200": {
                  "description": "OAuth callback processed successfully"
                }
              }
            }
          },
          "/api/v1/auth/gmail/status": {
            "get": {
              "summary": "Get Gmail OAuth connection status",
              "responses": {
                "200": {
                  "description": "OAuth status retrieved",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "connected": {"type": "boolean"},
                          "gmail_email": {"type": "string"},
                          "scopes_granted": {"type": "array", "items": {"type": "string"}}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Email Analysis & Phishing Detection",
      "description": "Advanced phishing detection using ML models, threat intelligence, and rule-based analysis for Gmail emails",
      "files": [
        "backend/app/api/email_analysis.py",
        "backend/app/api/gmail_simple.py",
        "backend/app/services/email_processor.py",
        "backend/app/analyzers/real_threat_analyzer.py",
        "frontend/src/components/EmailAnalysis.tsx"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Email Analysis API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/email-analysis/analyze": {
            "post": {
              "summary": "Analyze email for phishing threats",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "subject": {"type": "string"},
                        "sender": {"type": "string"},
                        "content": {"type": "string"},
                        "headers": {"type": "object"}
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Email analysis completed",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "threat_score": {"type": "number"},
                          "risk_level": {"type": "string"},
                          "detections": {"type": "array"},
                          "analysis_details": {"type": "object"}
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "/api/gmail-simple/analyze": {
            "post": {
              "summary": "Analyze user's Gmail emails for phishing",
              "responses": {
                "200": {
                  "description": "Gmail emails analyzed successfully"
                }
              }
            }
          }
        }
      }
    },
