# Development Mode 1 Configuration
# DO NOT USE IN PRODUCTION
# DO NOT COMMIT REAL CREDENTIALS

# ============================================================================
# Mode 1 Control
# ============================================================================
MODE1_ENABLED=true
MODE1_AUTO_START=true
MODE1_FAIL_FAST=true  # Fail fast in development
MODE1_STARTUP_HEALTH_CHECK=true

# ============================================================================
# IMAP Configuration (Development)
# ============================================================================
IMAP_CLIENT_TYPE=fake  # Use 'fake' for tests, 'real' for actual IMAP
IMAP_FAKE_MAILBOX_FIXTURE=tests/fixtures/dev_mailbox.json

# For real IMAP testing (use app passwords, not real passwords)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=dev-test@example.com
IMAP_PASSWORD=fake-password-for-dev  # DO NOT COMMIT REAL PASSWORD

# ============================================================================
# Database (Development)
# ============================================================================
MONGODB_URI=mongodb://localhost:27017/phishnet_dev
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# External APIs (Development - Use Test Keys)
# ============================================================================
VIRUSTOTAL_API_KEY=your-dev-api-key-here
GOOGLE_API_KEY=your-dev-gemini-key-here
ABUSEIPDB_API_KEY=your-dev-api-key-here

# ============================================================================
# Mode 1 Processing
# ============================================================================
MODE1_DEFAULT_POLL_INTERVAL=60
MODE1_BATCH_SIZE=10  # Small batch for dev
MODE1_MAX_CONCURRENT_TENANTS=2
MODE1_DEDUP_ENABLED=true
MODE1_POLICY_ENGINE_ENABLED=true

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# ============================================================================
# IMPORTANT NOTES
# ============================================================================
# 1. This is for DEVELOPMENT ONLY
# 2. DO NOT commit real credentials to version control
# 3. Use fake IMAP client for fast, deterministic tests
# 4. Real IMAP should use app passwords, not account passwords
# 5. Keep batch sizes small in dev to avoid overwhelming services
