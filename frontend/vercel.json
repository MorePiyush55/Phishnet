{
  "version": 2,
  "name": "phishnet-frontend",
  "buildCommand": "echo 'Static Deployment'",
  "outputDirectory": ".",
  "public": true,
  "env": {
    "BACKEND_URL": "https://phishnet-backend-iuoc.onrender.com"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://phishnet-backend-iuoc.onrender.com/$1"
    },
    {
      "source": "/auth/(.*)",
      "destination": "https://phishnet-backend-iuoc.onrender.com/auth/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}