# PhishNet Frontend Production Environment Variables
# =================================================
# 
# Production configuration for Vercel deployment with Render backend

# ==========================================
# API CONFIGURATION - PRODUCTION
# ==========================================

# Production API URLs - Updated for Render backend
VITE_API_BASE_URL=https://phishnet-backend-iuoc.onrender.com
VITE_API_URL=https://phishnet-backend-iuoc.onrender.com
VITE_WS_BASE_URL=wss://phishnet-backend-iuoc.onrender.com
VITE_PRODUCTION_API_URL=https://phishnet-backend-iuoc.onrender.com
VITE_PRODUCTION_WS_URL=wss://phishnet-backend-iuoc.onrender.com

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================

# Application Settings
VITE_APP_TITLE=PhishNet - Gmail Security Monitoring
VITE_APP_VERSION=1.0.0

# ==========================================
# GOOGLE OAUTH CONFIGURATION
# ==========================================

# Google OAuth Configuration - Use production values
VITE_GOOGLE_CLIENT_ID=your-production-google-client-id
VITE_GOOGLE_PROJECT_ID=your-google-project-id

# ==========================================
# FEATURE FLAGS - PRODUCTION
# ==========================================

# Production feature settings
VITE_ENABLE_DEBUG=false
VITE_ENABLE_DEVTOOLS=false
VITE_ENABLE_ANALYTICS=true

# ==========================================
# PERFORMANCE CONFIGURATION
# ==========================================

# Rate limiting for production
VITE_SCAN_RATE_LIMIT=5
VITE_SCAN_WINDOW_MS=300000

# ==========================================
# WEBSOCKET CONFIGURATION
# ==========================================

# WebSocket settings for production
VITE_SSE_MAX_RECONNECT_ATTEMPTS=10
VITE_SSE_RECONNECT_INTERVAL=5000

# ==========================================
# DEPLOYMENT CONFIGURATION
# ==========================================

# Production server configuration
VITE_PORT=3000
VITE_HOST=0.0.0.0

# CDN and Asset Configuration
VITE_CDN_URL=https://your-cdn-domain.com
VITE_STATIC_URL=https://your-static-assets-domain.com

# ==========================================
# MONITORING AND ANALYTICS
# ==========================================

# Analytics Configuration
VITE_ANALYTICS_ID=your-analytics-id
VITE_SENTRY_DSN=your-sentry-dsn-for-error-tracking

# Performance Monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true

# ==========================================
# SECURITY CONFIGURATION
# ==========================================

# Content Security Policy
VITE_CSP_REPORT_URI=https://your-api-domain.com/csp-report

# Security Headers
VITE_ENABLE_SECURITY_HEADERS=true