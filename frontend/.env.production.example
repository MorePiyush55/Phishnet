# Production Environment Configuration for PhishNet Frontend
# Copy this to .env.production for Vercel deployment

# API Configuration
VITE_API_URL=https://your-render-app.onrender.com
VITE_WS_URL=wss://your-render-app.onrender.com/ws

# Environment
VITE_ENVIRONMENT=production
VITE_APP_VERSION=1.0.0
VITE_BUILD_TIME=2024-01-01T00:00:00Z

# Analytics (Optional)
VITE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# Security (Optional)
VITE_CSP_NONCE=
VITE_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Feature Flags
VITE_ENABLE_REAL_TIME=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_PUSH_NOTIFICATIONS=false
VITE_ENABLE_BACKGROUND_SYNC=true

# Performance
VITE_CACHE_TIMEOUT=300000
VITE_MAX_RETRIES=3
VITE_REQUEST_TIMEOUT=30000

# OAuth Configuration
VITE_OAUTH_REDIRECT_URI=https://your-frontend.vercel.app/auth/callback
VITE_OAUTH_CLIENT_ID=your-google-client-id

# Rate Limiting
VITE_RATE_LIMIT_REQUESTS=10
VITE_RATE_LIMIT_WINDOW=60000

# Development/Debugging (set to false in production)
VITE_ENABLE_DEVTOOLS=false
VITE_ENABLE_DEBUG_LOGS=false
VITE_ENABLE_MOCK_DATA=false